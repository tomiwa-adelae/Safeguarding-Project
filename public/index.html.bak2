// Move MODULES to PSTAR namespace
PSTAR.MODULES = MODULES;

// ═══════════ LOGIN ═══════════
function initLogin() {
  const logoSrc = document.getElementById('starLogoSrc').value;
  document.getElementById('loginLogo').src = logoSrc;

  // Check for last used staff ID in sessionStorage (lightweight local hint only)
  const lastId = sessionStorage.getItem('pstar_lastId');
  if (lastId) {
    document.getElementById('loginStaffId').value = lastId;
    checkReturningUser(lastId);
  }
}

async function checkReturningUser(staffId) {
  try {
    const data = await api('GET', '/api/user/' + encodeURIComponent(staffId));
    if (data.exists) {
      document.getElementById('loginName').value = data.name;
      if (data.role) document.getElementById('loginRole').value = data.role;
      const retDiv = document.getElementById('returningUser');
      retDiv.style.display = 'block';
      retDiv.innerHTML = '<div class="login-returning"><strong>Welcome back, ' + data.name + '!</strong><span>' + data.completedCount + ' of 8 modules completed. Sign in to continue where you left off.</span></div>';
    }
  } catch (e) {}
}

// On staff ID blur, check if returning
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('loginStaffId').addEventListener('blur', function() {
    const val = this.value.trim();
    if (val.length > 2) checkReturningUser(val);
  });
});

document.addEventListener('DOMContentLoaded', () => {
  // Bind the login button
  const loginBtn = document.getElementById('loginBtn');
  if (loginBtn) {
    loginBtn.addEventListener('click', handleLogin);
  }
  
  // Bind the admin link
  const adminLink = document.getElementById('adminLoginLink');
  if (adminLink) {
    adminLink.addEventListener('click', showAdminLogin);
  }

  // Bind the login button
  const beginCourse = document.getElementById('beginCourse');
  if (beginCourse) {
    beginCourse.addEventListener('click', startCourse);
  }
});

async function handleLogin() {
  const name = document.getElementById('loginName').value.trim();
  const staffId = document.getElementById('loginStaffId').value.trim();
  const role = document.getElementById('loginRole').value;
  const errEl = document.getElementById('loginError');

  if (!name) { errEl.textContent = 'Please enter your full name.'; errEl.style.display = 'block'; return; }
  if (!staffId) { errEl.textContent = 'Please enter your Staff ID or email.'; errEl.style.display = 'block'; return; }
  if (!role) { errEl.textContent = 'Please select your role.'; errEl.style.display = 'block'; return; }

  errEl.style.display = 'none';


  try {
    const data = await api('POST', '/api/login', { staffId, name, role });
    currentUser = data.user;
    state.completed = data.state.completed || {};
    state.quizAnswers = data.state.quizAnswers || {};

    sessionStorage.setItem('pstar_lastId', staffId);

    document.getElementById('loginScreen').style.display = 'none';

    const completedCount = Object.keys(state.completed).length;
    if (completedCount > 0) {
      document.getElementById('splash').style.display = 'none';
      document.getElementById('topbar').classList.add('active');
      state.started = true;
      showDashboard();
    } else {
      document.getElementById('splash').style.display = 'flex';
    }
  } catch (e) {
    errEl.textContent = 'Connection error. Please try again.';
    errEl.style.display = 'block';
  }
}

// ═══════════ ADMIN LOGIN ═══════════
function showAdminLogin() {
  document.getElementById('adminLoginOverlay').style.display = 'flex';
  document.getElementById('adminPass').focus();
}
function hideAdminLogin() {
  document.getElementById('adminLoginOverlay').style.display = 'none';
  document.getElementById('adminPass').value = '';
  document.getElementById('adminError').style.display = 'none';
}
async function handleAdminLogin() {
  const pass = document.getElementById('adminPass').value;
  try {
    const res = await fetch('/api/admin/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ passphrase: pass })
    });
    if (res.ok) {
      adminKey = pass;
      hideAdminLogin();
      document.getElementById('loginScreen').style.display = 'none';
      document.getElementById('splash').style.display = 'none';
      showTracker();
    } else {
      const err = document.getElementById('adminError');
      err.textContent = 'Incorrect passphrase. Please try again.';
      err.style.display = 'block';
    }
  } catch (e) {
    document.getElementById('adminError').textContent = 'Connection error.';
    document.getElementById('adminError').style.display = 'block';
  }
}

// ═══════════ COURSE INIT ═══════════
function startCourse() {
  document.getElementById('splash').style.display = 'none';
  document.getElementById('topbar').classList.add('active');
  state.started = true;
  showDashboard();
}

function showDashboard() {
  hideAll();
  document.getElementById('dashboard').classList.add('active');
  updateUserBadge();
  renderModuleNav();
  updateProgress();
}

function hideAll() {
  document.getElementById('dashboard').classList.remove('active');
  document.getElementById('moduleContainer').classList.remove('active');
  document.getElementById('certificate').classList.remove('active');
  document.getElementById('trackerScreen').classList.remove('active');
}

function updateUserBadge() {
  let badge = document.getElementById('userBadge');
  if (!badge && currentUser) {
    const topbar = document.getElementById('topbar');
    badge = document.createElement('div');
    badge.id = 'userBadge';
    badge.style.cssText = 'font-size:.8rem;color:var(--text-light);margin-left:auto;white-space:nowrap;display:flex;align-items:center;gap:.5rem;';
    badge.innerHTML = '<span>👤 ' + currentUser.name + '</span><a onclick="logoutUser()" style="font-size:.75rem;cursor:pointer;color:var(--text-muted);text-decoration:underline">Sign out</a>';
    topbar.appendChild(badge);
  }
}

function logoutUser() {
  currentUser = null;
  state = { started: false, currentModule: null, completed: {}, quizAnswers: {} };
  hideAll();
  document.getElementById('topbar').classList.remove('active');
  const badge = document.getElementById('userBadge');
  if (badge) badge.remove();
  document.getElementById('loginScreen').style.display = 'flex';
  document.getElementById('splash').style.display = 'none';
  initLogin();
}

// ═══════════ MODULE NAV ═══════════
function renderModuleNav() {
  const nav = document.getElementById('moduleNav');
  nav.innerHTML = MODULES.map((m, i) => {
    const done = state.completed[m.id];
    const cls = done ? 'completed' : (state.currentModule === m.id ? 'current' : '');
    return '<div class="module-card ' + cls + '" onclick="openModule(\'' + m.id + '\')">' +
      '<div class="mc-num">' + m.num + '</div>' +
      '<div class="mc-title">' + m.title + '</div>' +
      '<div class="mc-desc">' + m.desc + '</div>' +
      '<div class="mc-status ' + (done ? 'done' : '') + '">' + (done ? '✓' : (i + 1)) + '</div>' +
    '</div>';
  }).join('');

  const allDone = MODULES.every(m => state.completed[m.id]);
  if (allDone) {
    nav.innerHTML += '<div class="module-card" style="border:2px solid var(--green);background:linear-gradient(135deg,var(--green-light),#d4edda);cursor:pointer;grid-column:1/-1;text-align:center" onclick="showCertificate()">' +
      '<div class="mc-title" style="font-size:1.2rem;color:var(--green-dark)">🎓 View Your Certificate</div>' +
      '<div class="mc-desc">All modules completed! Claim your certificate of completion.</div>' +
    '</div>';
  }
}

// ═══════════ OPEN MODULE ═══════════
function openModule(id) {
  const mod = MODULES.find(m => m.id === id);
  if (!mod) return;
  state.currentModule = id;
  hideAll();
  const container = document.getElementById('moduleContainer');
  container.classList.add('active');

  container.innerHTML = `
    <div class="module-view active">
      <div class="module-header">
        <img src="${document.getElementById('starLogoSrc').value}" class="star-logo-sm" alt="Project STAR LGS" style="position:absolute;top:1.2rem;right:1.5rem;height:36px;opacity:.7">
        <div class="mh-num">${mod.num} of ${MODULES.length}</div>
        <h2>${mod.title}</h2>
        <p>${mod.desc}</p>
      </div>
      ${mod.content}
      <div class="quiz-section" id="quiz-${id}">
        <h3>📝 Knowledge Check</h3>
        <p class="quiz-subtitle">Answer all questions to complete this module. You need 80% to pass.</p>
        ${mod.quiz.map((q, qi) => `
          <div class="quiz-q" id="q-${id}-${qi}">
            <p>${qi + 1}. ${q.q}</p>
            ${q.opts.map((o, oi) => `
              <label>
                <input type="radio" name="q-${id}-${qi}" value="${oi}" onchange="selectAnswer('${id}',${qi},${oi})">
                ${o}
              </label>
            `).join('')}
            <div class="feedback" id="fb-${id}-${qi}"></div>
          </div>
        `).join('')}
        <div id="result-${id}" class="quiz-result"></div>
        <button class="btn btn-green" id="submitBtn-${id}" onclick="submitQuiz('${id}')">Submit Answers</button>
      </div>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1rem">
        ${getModuleIndex(id) > 0 ? '<button class="btn btn-outline" onclick="openModule(\'' + MODULES[getModuleIndex(id) - 1].id + '\')">← Previous</button>' : ''}
        <button class="btn btn-outline" onclick="showDashboard()">Dashboard</button>
        ${getModuleIndex(id) < MODULES.length - 1 ? '<button class="btn btn-green" onclick="openModule(\'' + MODULES[getModuleIndex(id) + 1].id + '\')">Next Module →</button>' : ''}
      </div>
    </div>`;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function getModuleIndex(id) {
  return MODULES.findIndex(m => m.id === id);
}

// ═══════════ QUIZ ═══════════
function selectAnswer(modId, qIdx, optIdx) {
  if (!state.quizAnswers[modId]) state.quizAnswers[modId] = {};
  state.quizAnswers[modId][qIdx] = optIdx;
  // Debounced server save
  clearTimeout(selectAnswer._timer);
  selectAnswer._timer = setTimeout(() => {
    saveQuizAnswersToServer(modId, state.quizAnswers[modId]);
  }, 1500);
}

async function submitQuiz(modId) {
  const mod = MODULES.find(m => m.id === modId);
  let correct = 0;
  mod.quiz.forEach((q, qi) => {
    const selected = state.quizAnswers[modId]?.[qi];
    const fb = document.getElementById('fb-' + modId + '-' + qi);
    if (selected === q.ans) {
      correct++;
      fb.className = 'feedback correct';
      fb.innerHTML = '✅ Correct! ' + q.explain;
    } else {
      fb.className = 'feedback incorrect';
      fb.innerHTML = '❌ Incorrect. ' + q.explain;
    }
    document.querySelectorAll('input[name="q-' + modId + '-' + qi + '"]').forEach(inp => inp.disabled = true);
  });

  const total = mod.quiz.length;
  const pct = Math.round((correct / total) * 100);
  const passed = pct >= 80;

  const result = document.getElementById('result-' + modId);
  result.style.display = 'block';
  result.className = 'quiz-result ' + (passed ? 'pass' : 'fail');
  result.innerHTML = '<div class="quiz-score">' + pct + '%</div>' +
    '<h4>' + (passed ? '🎉 Module Passed!' : '⚠️ Not Yet Passed') + '</h4>' +
    '<p>' + (passed ? 'You scored ' + correct + '/' + total + '. This module is now complete.' : 'You scored ' + correct + '/' + total + '. You need 80% to pass. Review the material and try again.') + '</p>' +
    (!passed ? '<button class="btn btn-outline btn-sm" onclick="retryQuiz(\'' + modId + '\')" style="margin-top:1rem">Retry Quiz</button>' : '');

  if (passed) {
    state.completed[modId] = { score: correct, total, passed: true, completedAt: new Date().toISOString() };
    document.getElementById('submitBtn-' + modId).style.display = 'none';
    await saveModuleProgress(modId, correct, total, true);
  }
  updateProgress();
}

function retryQuiz(modId) {
  state.quizAnswers[modId] = {};
  saveQuizAnswersToServer(modId, {});
  openModule(modId);
  setTimeout(() => {
    document.getElementById('quiz-' + modId).scrollIntoView({ behavior: 'smooth' });
  }, 300);
}

// ═══════════ PROGRESS ═══════════
function updateProgress() {
  const done = Object.keys(state.completed).length;
  const total = MODULES.length;
  const pct = Math.round((done / total) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressPct').textContent = pct + '%';

  const ring = document.getElementById('ringFg');
  const ringPct = document.getElementById('ringPct');
  if (ring && ringPct) {
    const circumference = 345.58;
    ring.style.strokeDashoffset = circumference - (circumference * pct / 100);
    ringPct.textContent = pct + '%';
  }
}

// ═══════════ CERTIFICATE ═══════════
async function showCertificate() {
  const allDone = MODULES.every(m => state.completed[m.id]);
  if (!allDone) return;
  hideAll();
  document.getElementById('certificate').classList.add('active');
  document.getElementById('certDate').textContent = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  document.getElementById('certName').textContent = currentUser ? currentUser.name : 'Learner';
  if (currentUser) {
    await api('POST', '/api/certificate', { staffId: currentUser.staffId });
  }
}

// ═══════════ ADMIN TRACKER ═══════════
async function showTracker() {
  hideAll();
  document.getElementById('topbar').classList.remove('active');
  document.getElementById('trackerScreen').classList.add('active');
  await refreshTracker();
}

let trackerCache = [];

async function refreshTracker() {
  try {
    const data = await api('GET', '/api/admin/tracker?key=' + encodeURIComponent(adminKey));
    trackerCache = data.users || [];
  } catch (e) {
    trackerCache = [];
  }

  const totalUsers = trackerCache.length;
  const completedUsers = trackerCache.filter(u => Object.keys(u.completed || {}).length === 8).length;
  const inProgressUsers = trackerCache.filter(u => { const c = Object.keys(u.completed || {}).length; return c > 0 && c < 8; }).length;
  const notStarted = totalUsers - completedUsers - inProgressUsers;
  const avgProgress = totalUsers > 0 ? Math.round(trackerCache.reduce((s, u) => s + Object.keys(u.completed || {}).length, 0) / totalUsers / 8 * 100) : 0;

  document.getElementById('trackerStats').innerHTML =
    '<div class="tracker-stat-card"><div class="tsc-val">' + totalUsers + '</div><div class="tsc-label">Total Enrolled</div></div>' +
    '<div class="tracker-stat-card"><div class="tsc-val" style="color:var(--green)">' + completedUsers + '</div><div class="tsc-label">Fully Completed</div></div>' +
    '<div class="tracker-stat-card"><div class="tsc-val" style="color:var(--amber)">' + inProgressUsers + '</div><div class="tsc-label">In Progress</div></div>' +
    '<div class="tracker-stat-card"><div class="tsc-val" style="color:var(--text-muted)">' + notStarted + '</div><div class="tsc-label">Not Started</div></div>' +
    '<div class="tracker-stat-card"><div class="tsc-val">' + avgProgress + '%</div><div class="tsc-label">Avg. Progress</div></div>';

  renderTrackerTable(trackerCache);
}

function renderTrackerTable(users) {
  const body = document.getElementById('trackerBody');
  const empty = document.getElementById('trackerEmpty');

  if (users.length === 0) {
    body.innerHTML = '';
    empty.style.display = 'block';
    empty.textContent = 'No learners have enrolled yet.';
    return;
  }
  empty.style.display = 'none';

  body.innerHTML = users.map(u => {
    const comp = u.completed || {};
    const completedCount = Object.keys(comp).length;
    const pct = Math.round(completedCount / 8 * 100);
    const lastActive = u.lastActive ? new Date(u.lastActive).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '—';

    const moduleDots = MODULES.map(m => {
      const done = comp[m.id];
      return '<span class="mod-dot ' + (done ? 'done' : 'pending') + '" title="' + m.title + (done ? ' ✓' : '') + '">' + (done ? '✓' : '') + '</span>';
    }).join('');

    return '<tr onclick="showUserDetail(\'' + u.staffId.replace(/'/g, "\\'") + '\')" style="cursor:pointer">' +
      '<td><strong>' + u.name + '</strong></td>' +
      '<td style="font-family:JetBrains Mono,monospace;font-size:.8rem">' + u.staffId + '</td>' +
      '<td>' + (u.role || '—') + '</td>' +
      '<td><div style="display:flex;align-items:center;gap:.5rem"><div class="progress-bar-sm"><div class="fill" style="width:' + pct + '%"></div></div><span style="font-family:JetBrains Mono,monospace;font-size:.8rem;min-width:35px">' + pct + '%</span></div></td>' +
      '<td colspan="8" style="text-align:center">' + moduleDots + '</td>' +
      '<td style="font-size:.82rem;color:var(--text-light)">' + lastActive + '</td>' +
      '<td style="color:var(--text-muted);font-size:.8rem">→</td>' +
    '</tr>';
  }).join('');
}

function filterTracker() {
  const q = document.getElementById('trackerSearchInput').value.toLowerCase().trim();
  const filtered = trackerCache.filter(u => {
    if (!q) return true;
    return u.name.toLowerCase().includes(q) ||
           u.staffId.toLowerCase().includes(q) ||
           (u.role || '').toLowerCase().includes(q);
  });
  renderTrackerTable(filtered);
  document.getElementById('trackerEmpty').style.display = filtered.length === 0 ? 'block' : 'none';
  if (filtered.length === 0) document.getElementById('trackerEmpty').textContent = 'No learners found matching your search.';
}

function showUserDetail(staffId) {
  const data = trackerCache.find(u => u.staffId === staffId);
  if (!data) return;
  const comp = data.completed || {};
  const completedCount = Object.keys(comp).length;
  const pct = Math.round(completedCount / 8 * 100);

  const card = document.getElementById('userDetailCard');
  card.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1.5rem"><div>' +
    '<h3 style="margin-bottom:.3rem">' + data.name + '</h3>' +
    '<p style="font-size:.9rem;color:var(--text-light)">' + data.staffId + ' · ' + (data.role || '—') + '</p>' +
    '<p style="font-size:.82rem;color:var(--text-muted);margin-top:.3rem">Enrolled: ' + (data.firstLogin ? new Date(data.firstLogin).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '—') + '</p>' +
    '</div><div style="text-align:center"><div style="font-family:JetBrains Mono,monospace;font-size:2rem;font-weight:700;color:var(--green-dark)">' + pct + '%</div><div style="font-size:.78rem;color:var(--text-muted)">' + completedCount + ' of 8</div></div></div>' +
    '<div style="border-top:1px solid var(--border);padding-top:1rem">' +
    MODULES.map(m => {
      const done = comp[m.id];
      const dateStr = done?.completedAt ? new Date(done.completedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) : '';
      const scoreStr = done ? done.score + '/' + done.total + ' (' + Math.round(done.score/done.total*100) + '%)' : '';
      return '<div class="udm-row"><div class="udm-module">' + m.num + '. ' + m.title + '</div>' +
        '<div style="display:flex;align-items:center;gap:.6rem">' +
        (scoreStr ? '<span style="font-size:.8rem;color:var(--text-light);font-family:JetBrains Mono,monospace">' + scoreStr + '</span>' : '') +
        (dateStr ? '<span style="font-size:.75rem;color:var(--text-muted)">' + dateStr + '</span>' : '') +
        '<span class="udm-status ' + (done ? 'complete' : 'incomplete') + '">' + (done ? 'Complete' : 'Incomplete') + '</span></div></div>';
    }).join('') +
    '</div>' +
    '<div style="margin-top:1.5rem;text-align:right"><button class="btn btn-sm btn-outline" onclick="closeUserDetail()">Close</button></div>';

  document.getElementById('userDetailModal').style.display = 'flex';
}

function closeUserDetail() {
  document.getElementById('userDetailModal').style.display = 'none';
}

function exportTrackerCSV() {
  // Direct download from server
  window.open('/api/admin/export?key=' + encodeURIComponent(adminKey), '_blank');
}

function logoutAdmin() {
  adminKey = null;
  hideAll();
  document.getElementById('trackerScreen').classList.remove('active');
  document.getElementById('loginScreen').style.display = 'flex';
  initLogin();
}

// ═══════════ BOOT ═══════════
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('splash').style.display = 'none';
  initLogin();
});

</script>
</body>
</html>