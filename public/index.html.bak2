<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project STAR Safeguarding Course</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Source+Sans+3:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<!-- ═══════════ TOP BAR ═══════════ -->
<div class="topbar" id="topbar">
  <div class="topbar-progress"><div class="topbar-progress-fill" id="progressFill"></div></div>
  <div class="topbar-pct" id="progressPct">0%</div>
  <button class="btn btn-sm btn-outline" onclick="showDashboard()">Dashboard</button>
</div>


<!-- ═══════════ LOGIN SCREEN ═══════════ -->
<div class="login-screen" id="loginScreen">
  <div class="login-card">
    <img src="" id="loginLogo" alt="Project STAR LGS">
    <h2>Safeguarding Training</h2>
    <p class="login-sub">Sign in to track your progress across sessions</p>
    <div class="login-error" id="loginError"></div>
    <div id="returningUser" style="display:none"></div>
    <div class="login-field">
      <label for="loginName">Full Name</label>
      <input type="text" id="loginName" placeholder="e.g. Bukola Adeleke" autocomplete="name">
    </div>
    <div class="login-field">
      <label for="loginStaffId">Staff ID / Email</label>
      <input type="text" id="loginStaffId" placeholder="e.g. adeleke.bu@projectstarlgs.com" autocomplete="email">
      <div class="field-hint">This is your unique identifier to save and resume progress</div>
    </div>
    <div class="login-field">
      <label for="loginRole">Role</label>
      <select id="loginRole">
        <option value="">Select your role...</option>
        <option value="Teacher / Instructor">Teacher / Instructor</option>
        <option value="CBT Supervisor">CBT Supervisor</option>
        <option value="Invigilator">Invigilator</option>
        <option value="Digital Skills Facilitator">Digital Skills Facilitator</option>
        <option value="Administrative Staff">Administrative Staff</option>
        <option value="Volunteer">Volunteer</option>
        <option value="Board Member">Board Member</option>
        <option value="DSL / Deputy DSL">DSL / Deputy DSL</option>
        <option value="Other">Other</option>
      </select>
    </div>
    <button class="login-btn" id="loginBtn">Continue to Course →</button>
    <div class="login-divider">or</div>
<a class="login-admin-link" id="adminLoginLink">Admin / Tracker Access</a>  </div>
</div>

<!-- ═══════════ ADMIN LOGIN OVERLAY ═══════════ -->
<div id="adminLoginOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:300;align-items:center;justify-content:center;padding:1rem">
  <div class="login-card" style="max-width:380px">
    <h2 style="font-size:1.3rem;margin-bottom:1rem">Admin Access</h2>
    <div class="login-error" id="adminError"></div>
    <div class="login-field">
      <label for="adminPass">Admin Passphrase</label>
      <input type="password" id="adminPass" placeholder="Enter admin passphrase" onkeydown="if(event.key==='Enter')handleAdminLogin()">
    </div>
    <button class="login-btn" onclick="handleAdminLogin()">Access Tracker →</button>
    <br><a class="login-admin-link" onclick="hideAdminLogin()" style="margin-top:.8rem">← Back</a>
  </div>
</div>

<!-- ═══════════ SPLASH SCREEN ═══════════ -->
<div class="splash" id="splash">
  <div class="splash-inner">
    <div class="splash-badge">Interactive Training Course</div>
    <h1>Project STAR<br>Safeguarding Course</h1>
    <p>A comprehensive interactive training programme covering child protection, digital safety, reporting procedures, and your responsibilities under the Project STAR Safeguarding Policy.</p>
    <div class="splash-stats">
      <div class="splash-stat"><strong>8</strong><span>Modules</span></div>
      <div class="splash-stat"><strong>40</strong><span>Questions</span></div>
      <div class="splash-stat"><strong>~3hrs</strong><span>Duration</span></div>
    </div>
    <button class="btn btn-primary" id="beginCourse" style="animation:fadeDown .8s ease .4s both">
      Begin Course →
    </button>
  </div>
</div>

<!-- ═══════════ COURSE DASHBOARD ═══════════ -->
<div class="course" id="dashboard">
  <div class="dashboard-header">
    <h2>Course Dashboard</h2>
    <p style="color:var(--text-light)">Track your progress through all 8 modules</p>
    <div class="progress-ring">
      <svg width="130" height="130">
        <circle class="bg" cx="65" cy="65" r="55"></circle>
        <circle class="fg" id="ringFg" cx="65" cy="65" r="55" stroke-dasharray="345.58" stroke-dashoffset="345.58"></circle>
      </svg>
      <div class="pct" id="ringPct">0%</div>
    </div>
  </div>
  <div class="module-nav" id="moduleNav"></div>
</div>

<!-- ═══════════ MODULE VIEW CONTAINER ═══════════ -->
<div class="course" id="moduleContainer"></div>

<!-- ═══════════ CERTIFICATE ═══════════ -->
<div class="certificate" id="certificate">
  <div class="cert-frame">
    <h2>Certificate of Completion</h2>
    <p class="cert-sub">Project STAR Safeguarding Training</p>
    <div class="cert-name" id="certName">Learner</div>
    <p class="cert-detail">has successfully completed the</p>
    <p class="cert-detail"><strong>Project STAR Safeguarding Interactive Course</strong></p>
    <p class="cert-detail">covering child protection, digital safety, reporting procedures,<br>and safeguarding governance across all programme areas.</p>
    <p class="cert-date" id="certDate"></p>
    <div style="margin-top:2rem;display:flex;justify-content:center;gap:1rem;flex-wrap:wrap">
      <button class="btn btn-green" onclick="window.print()">🖨️ Print Certificate</button>
      <button class="btn btn-outline" onclick="showDashboard()">← Back to Dashboard</button>
    </div>
  </div>


<!-- ═══════════ ADMIN TRACKER ═══════════ -->
<div class="tracker-screen" id="trackerScreen">
  <div class="tracker-header">
    <div>
      <h2>📊 Completion Tracker</h2>
      <p style="color:var(--text-light);font-size:.9rem">Monitor safeguarding training progress across all staff</p>
    </div>
    <div class="tracker-header-actions">
      <button class="btn btn-sm btn-outline" onclick="exportTrackerCSV()">📥 Export CSV</button>
      <button class="btn btn-sm btn-outline" onclick="refreshTracker()">🔄 Refresh</button>
      <button class="btn btn-sm btn-outline" onclick="logoutAdmin()">← Sign Out</button>
    </div>
  </div>
  <div class="tracker-stats" id="trackerStats"></div>
  <div class="tracker-table-wrap">
    <div class="tracker-search">
      <input type="text" id="trackerSearchInput" placeholder="Search by name, staff ID, or role..." oninput="filterTracker()">
    </div>
    <table class="tracker-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Staff ID</th>
          <th>Role</th>
          <th>Progress</th>
          <th>M1</th><th>M2</th><th>M3</th><th>M4</th><th>M5</th><th>M6</th><th>M7</th><th>M8</th>
          <th>Last Active</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="trackerBody"></tbody>
    </table>
    <div class="tracker-empty" id="trackerEmpty" style="display:none">No learners found matching your search.</div>
  </div>
</div>

<!-- ═══════════ USER DETAIL MODAL ═══════════ -->
<div id="userDetailModal" class="user-detail-modal" style="display:none" onclick="if(event.target===this)closeUserDetail()">
  <div class="user-detail-card" id="userDetailCard"></div>
</div>

<!-- JavaScript Files -->
<script src="/js/config.js"></script>
<script src="/js/state.js"></script>
<script src="/js/api.js"></script>
<script src="/js/ui.js"></script>

<script>
const MODULES = [
  {
    id: 'm1',
    num: 'Module 1',
    title: 'Introduction to Safeguarding',
    desc: 'Policy statement, purpose, and core principles',
    content: `
      <div class="content-section">
        <h3>What is Safeguarding?</h3>
        <p>Safeguarding is the action taken to promote the welfare of children and protect them from harm. At Project STAR, safeguarding means:</p>
        <ul>
          <li><strong>Protecting</strong> children from abuse and maltreatment</li>
          <li><strong>Preventing</strong> harm to children's health or development</li>
          <li><strong>Ensuring</strong> children grow up with safe and effective care</li>
          <li><strong>Taking action</strong> to enable all children to have the best outcomes</li>
        </ul>
        <div class="info-box tip">
          <div class="ib-icon">💡</div>
          <p><strong>Key Principle:</strong> Safeguarding is EVERYONE'S responsibility — all staff, volunteers, and partners have a duty to keep children and young people safe.</p>
        </div>
      </div>
      <div class="content-section">
        <h3>Project STAR's Commitment</h3>
        <p>Project STAR maintains a <strong>zero-tolerance</strong> approach to any form of abuse, exploitation, or harm to children and young people. Our safeguarding framework integrates five pillars:</p>
        <div class="accordion">
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">🏛️ Regulatory Alignment <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Full compliance with the Child Rights Act 2003, Oyo State MoEST guidelines, JAMB examination protocols, and WAEC conduct standards.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">🏗️ Governance Structure <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Designated Safeguarding Lead (DSL) with direct Board accountability, supported by Session Safeguarding Leads and clear escalation pathways.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">🛡️ Preventative Controls <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Mandatory background checks, comprehensive training, supervised environments, and programme-specific risk mitigation.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">📋 Response Protocols <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Clear incident reporting, investigation procedures, and multi-agency cooperation framework.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">🔄 Continuous Improvement <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Annual policy review, quarterly safeguarding audits, and learning from incidents.</div></div>
          </div>
        </div>
      </div>
      <div class="content-section">
        <h3>Who Does This Policy Apply To?</h3>
        <p>The safeguarding policy is binding on <strong>all individuals and organisations</strong> associated with Project STAR:</p>
        <table class="resp-table">
          <tr><th>Category</th><th>Who</th></tr>
          <tr><td>Direct Personnel</td><td>All staff (full-time, part-time, temporary, casual), volunteers, trustees, Board members, consultants, contractors</td></tr>
          <tr><td>Partner Organisations</td><td>Lagelu Grammar School staff, I-World Limited personnel, third-party service providers</td></tr>
          <tr><td>Visitors</td><td>Funders, inspectors, regulators, guest speakers, facilitators</td></tr>
        </table>
        <div class="info-box info">
          <div class="ib-icon">📌</div>
          <p>A <strong>child</strong> is defined as any person under the age of 18 years, aligned with the Child Rights Act 2003. Vulnerable adults aged 18+ are also afforded appropriate protections.</p>
        </div>
      </div>
      <div class="content-section">
        <h3>Programme Coverage</h3>
        <p>This policy covers all Project STAR programmes:</p>
        <div class="tabs">
          <div class="tab active" onclick="switchTab(this,'tab-cbt1')">CBT Services</div>
          <div class="tab" onclick="switchTab(this,'tab-dsa1')">Digital Skills Academy</div>
          <div class="tab" onclick="switchTab(this,'tab-acad1')">Academic Support</div>
        </div>
        <div class="tab-panel active" id="tab-cbt1">
          <p>JAMB UTME and Direct Entry examination practice, WAEC exam preparation and mock testing, Post-UTME preparation sessions, supervised CBT practice sessions, and CBT centre operations at Lagelu Grammar School.</p>
        </div>
        <div class="tab-panel" id="tab-dsa1">
          <p>Digital literacy training, coding and programming courses, data analysis and ICT skills development, online and blended learning delivery, and digital mentoring and coaching programmes.</p>
        </div>
        <div class="tab-panel" id="tab-acad1">
          <p>Junior Secondary School (JSS) tutorial support, Senior Secondary School (SSS) academic enrichment, revision and examination preparation classes, and study skills and learning support sessions.</p>
        </div>
      </div>
    `,
    quiz: [
      { q: 'What is the primary purpose of safeguarding?', opts: ['Enforcing discipline on students', 'Promoting welfare of children and protecting them from harm', 'Managing examination schedules', 'Processing student admissions'], ans: 1, explain: 'Safeguarding is the action taken to promote the welfare of children and protect them from harm.' },
      { q: 'Who does the Project STAR Safeguarding Policy apply to?', opts: ['Only full-time staff', 'Only those working directly with children', 'All individuals and organisations associated with Project STAR', 'Only the DSL and Board members'], ans: 2, explain: 'The policy is binding on ALL individuals and organisations associated with Project STAR — staff, volunteers, partners, and visitors.' },
      { q: 'Under the Child Rights Act 2003, what age defines a child?', opts: ['Under 16', 'Under 18', 'Under 21', 'Under 14'], ans: 1, explain: 'A child is any person under the age of 18 years, aligned with the Child Rights Act 2003.' },
      { q: 'What approach does Project STAR take to abuse and exploitation?', opts: ['Case-by-case evaluation', 'Zero tolerance', 'Three-strike policy', 'Informal resolution'], ans: 1, explain: 'Project STAR maintains a zero-tolerance approach to any form of abuse, exploitation, or harm.' },
      { q: 'Which of these is NOT a programme covered by the policy?', opts: ['CBT Services', 'Digital Skills Academy', 'Financial Advisory Services', 'Academic Support'], ans: 2, explain: 'The policy covers CBT Services, Digital Skills Academy, and Academic Support Programmes. Financial Advisory Services is not a Project STAR programme.' }
    ]
  },
  {
    id: 'm2',
    num: 'Module 2',
    title: 'Legal Framework & Governance',
    desc: 'Laws, regulations, and accountability structure',
    content: `
      <div class="content-section">
        <h3>Nigerian Legal Framework</h3>
        <p>Project STAR's safeguarding policy is grounded in several key pieces of Nigerian legislation:</p>
        <div class="accordion">
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">📜 Child Rights Act 2003 <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Establishes the rights of children, prohibits child abuse, neglect, and exploitation, and provides framework for child protection and welfare services.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">📜 Constitution of Nigeria 1999 <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Fundamental rights provisions applicable to children and non-discrimination principles.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">📜 Violence Against Persons (Prohibition) Act 2015 <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Protection against physical, sexual, psychological, and emotional abuse. Includes mandatory reporting requirements for suspected abuse.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">📜 Oyo State Child Rights Law <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">State-level implementation of Child Rights Act with local child protection service structures and responsibilities.</div></div>
          </div>
        </div>
      </div>
      <div class="content-section">
        <h3>Governance & Accountability Structure</h3>
        <p>Project STAR has a clear hierarchy of safeguarding accountability:</p>
        <table class="resp-table">
          <tr><th>Role</th><th>Reports To</th><th>Decision Authority</th><th>Response Time</th></tr>
          <tr><td><strong>Board Safeguarding Champion</strong></td><td>Full Board</td><td>Strategic oversight</td><td>Oversight role</td></tr>
          <tr><td><strong>DSL</strong></td><td>Director & Board</td><td>Full safeguarding authority</td><td>Immediate (serious)</td></tr>
          <tr><td><strong>Deputy DSL</strong></td><td>DSL</td><td>Acts as DSL when absent</td><td>Immediate (as DSL)</td></tr>
          <tr><td><strong>SSL (CBT)</strong></td><td>DSL</td><td>Session-level interventions</td><td>Report within 24 hrs</td></tr>
          <tr><td><strong>SSL (Digital Skills)</strong></td><td>DSL</td><td>Session-level interventions</td><td>Report within 24 hrs</td></tr>
          <tr><td><strong>Programme Staff</strong></td><td>Line Mgr & DSL</td><td>Report concerns only</td><td>Immediate reporting</td></tr>
          <tr><td><strong>Volunteers</strong></td><td>Coordinator & DSL</td><td>Report concerns only</td><td>Immediate reporting</td></tr>
        </table>
        <div class="info-box warning">
          <div class="ib-icon">⚠️</div>
          <p><strong>Current DSL:</strong> Bukola Adeleke (adeleke.bu@projectstarlgs.com)<br><strong>Deputy DSL:</strong> Rachael Ojerinde (ojerinde.ra@projectstarlgs.com)</p>
        </div>
      </div>
      <div class="content-section">
        <h3>Board Responsibilities</h3>
        <p>The Project STAR Board holds <strong>ultimate accountability</strong> for safeguarding. Key responsibilities include:</p>
        <ul>
          <li>Approving and reviewing the Safeguarding Policy <strong>annually</strong></li>
          <li>Ensuring adequate resources for effective safeguarding</li>
          <li>Receiving <strong>quarterly</strong> safeguarding reports from the DSL</li>
          <li>Reviewing serious incidents and lessons learned</li>
          <li>Appointing a Board Safeguarding Champion for additional scrutiny</li>
        </ul>
      </div>
    `,
    quiz: [
      { q: 'Which legislation is the primary legal foundation for child protection in Nigeria?', opts: ['Constitution 1999', 'Child Rights Act 2003', 'Violence Against Persons Act 2015', 'Education Act'], ans: 1, explain: 'The Child Rights Act 2003 is the primary legal framework establishing children\'s rights and child protection standards.' },
      { q: 'Who holds ULTIMATE accountability for safeguarding at Project STAR?', opts: ['The DSL', 'The Project Director', 'The Board', 'The Ministry of Education'], ans: 2, explain: 'The Project STAR Board holds ultimate accountability for safeguarding.' },
      { q: 'How often should the Board receive safeguarding reports?', opts: ['Monthly', 'Quarterly', 'Annually', 'Only when incidents occur'], ans: 1, explain: 'The Board receives quarterly safeguarding reports from the DSL.' },
      { q: 'Who is the current DSL for Project STAR?', opts: ['Rachael Ojerinde', 'Bukola Adeleke', 'The Board Chair', 'The School Principal'], ans: 1, explain: 'Bukola Adeleke is the current Designated Safeguarding Lead.' },
      { q: 'What is the Session Safeguarding Lead\'s reporting timeframe to the DSL?', opts: ['Immediately', 'Within 24 hours', 'Within 48 hours', 'At the next team meeting'], ans: 1, explain: 'SSLs must report all concerns to the DSL within 24 hours of a session.' }
    ]
  },
  {
    id: 'm3',
    num: 'Module 3',
    title: 'Recognising Abuse & Harm',
    desc: 'Types of abuse, indicators, and specific concerns',
    content: `
      <div class="content-section">
        <h3>Why Recognition Matters</h3>
        <p>Early recognition of abuse and harm is <strong>critical</strong> to protecting children. All Project STAR staff and volunteers must be trained and vigilant in recognising signs that a child is suffering or at risk of suffering harm.</p>
        <div class="info-box danger">
          <div class="ib-icon">🚨</div>
          <p>Remember: You do NOT need to be certain that abuse is occurring. If you have concerns or notice something that doesn't seem right, you must report it. It is the DSL's responsibility to investigate — not yours.</p>
        </div>
      </div>
      <div class="content-section">
        <h3>Types of Abuse</h3>
        <div class="tabs">
          <div class="tab active" onclick="switchTab(this,'tab-phys')">Physical</div>
          <div class="tab" onclick="switchTab(this,'tab-emot')">Emotional</div>
          <div class="tab" onclick="switchTab(this,'tab-sex')">Sexual</div>
          <div class="tab" onclick="switchTab(this,'tab-neg')">Neglect</div>
        </div>
        <div class="tab-panel active" id="tab-phys">
          <h4>Physical Abuse</h4>
          <p><strong>Physical signs:</strong> Unexplained injuries (bruises, burns, fractures), injuries in patterns, injuries at different stages of healing, wearing clothing to hide injuries.</p>
          <p><strong>Behavioural signs:</strong> Fear of physical contact, aggressive behaviour, withdrawn/anxious mood, running away, reluctance to go home, fear of specific individuals.</p>
        </div>
        <div class="tab-panel" id="tab-emot">
          <h4>Emotional Abuse</h4>
          <p><strong>Behavioural signs:</strong> Low self-esteem, withdrawn/anxious behaviour, difficulty forming relationships, developmental delay, self-harm, overly compliant or excessively aggressive.</p>
          <p><strong>Relationship patterns:</strong> Appears frightened of parents/guardians, describes self negatively, seeks constant approval.</p>
        </div>
        <div class="tab-panel" id="tab-sex">
          <h4>Sexual Abuse</h4>
          <p><strong>Physical signs:</strong> Pain/bleeding in genital areas, sexually transmitted infections, pregnancy, unexplained gifts or money.</p>
          <p><strong>Behavioural signs:</strong> Sexual knowledge inappropriate for age, regression, fear of specific people/places, self-harm, running away from home.</p>
          <p><strong>Disclosure indicators:</strong> Hints about secrets, mentions new adult "friend", refers to inappropriate online contact.</p>
        </div>
        <div class="tab-panel" id="tab-neg">
          <h4>Neglect</h4>
          <p><strong>Physical signs:</strong> Underweight/hungry, poor hygiene, inadequate clothing, untreated medical issues, persistent tiredness.</p>
          <p><strong>Developmental signs:</strong> Poor school attendance, developmental delay, poor concentration.</p>
          <p><strong>Behavioural signs:</strong> Withdrawn, compulsive eating/scavenging, takes on adult responsibilities, no supervision at home.</p>
        </div>
      </div>
      <div class="content-section">
        <h3>Specific Safeguarding Concerns at Project STAR</h3>
        <div class="accordion">
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">💻 Cyberbullying <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Reluctance to use devices, emotional distress after using technology, withdrawal from social interaction, changes in mood, evidence of threatening messages.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">📝 Examination Exploitation <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Sudden acquisition of money, pressure to achieve beyond capability, mentions of being offered "help" for payment, reluctance to discuss exam preparation.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">⚡ Radicalisation & Extremism <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Expressions of extremist views, intolerance of difference, isolation from friends/family, possession of extremist literature, accessing extremist material online.</div></div>
          </div>
          <div class="acc-item">
            <div class="acc-header" onclick="toggleAcc(this)">🔒 Child Sexual Exploitation (CSE) <span class="arrow">▼</span></div>
            <div class="acc-body"><div class="acc-body-inner">Unexplained gifts/money, associating with unknown older individuals, going missing, secretive behaviour, substance misuse.</div></div>
          </div>
        </div>
      </div>
      <div class="content-section">
        <h3>Barriers to Recognition</h3>
        <p>Be aware that certain factors can make abuse harder to recognise:</p>
        <ul>
          <li><strong>Disability:</strong> Children with disabilities may be particularly vulnerable; communication difficulties may mask signs</li>
          <li><strong>Cultural Factors:</strong> Cultural practices must be respected but never at the expense of child safety</li>
          <li><strong>Socioeconomic Factors:</strong> Poverty may explain some indicators but does not excuse neglect</li>
          <li><strong>Parental Pressure:</strong> High-achieving families may mask emotional abuse through academic pressure</li>
        </ul>
      </div>
    `,
    quiz: [
      { q: 'Which of the following is a behavioural indicator of emotional abuse?', opts: ['Unexplained bruises', 'Persistent hunger', 'Low self-esteem and difficulty forming relationships', 'Sexually inappropriate language'], ans: 2, explain: 'Low self-esteem and difficulty forming relationships are key indicators of emotional abuse.' },
      { q: 'A student suddenly has expensive new items and is secretive about their whereabouts. This could indicate:', opts: ['Good family circumstances', 'Child Sexual Exploitation', 'Normal adolescent behaviour', 'Academic success rewards'], ans: 1, explain: 'Unexplained gifts/money and secretive behaviour are warning signs of CSE.' },
      { q: 'What is a specific safeguarding concern unique to Project STAR\'s CBT context?', opts: ['Cyberbullying', 'Examination exploitation', 'FGM', 'Forced marriage'], ans: 1, explain: 'Examination exploitation — being pressured to engage in fraud or offered "help" for payment — is a specific concern in the CBT context.' },
